{
  "name": "gourcer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "start": "vite --host 127.0.0.1",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "sidecar:hell-ui": "tsx scripts/generate-sidecar.ts /Users/apieper/dev/hell-ui public/sidecars/hell-ui.json --max-commits=900 --name=hell-ui",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "e2e": "playwright test",
    "ci:install": "pnpm install --frozen-lockfile",
    "ci:playwright": "pnpm exec playwright install --with-deps chromium",
    "ci:e2e": "pnpm exec playwright test --project=chromium --project=mobile-chromium",
    "ci:test": "pnpm run lint && pnpm run test",
    "ci:build": "pnpm run build",
    "ci:verify": "pnpm run ci:test && pnpm run ci:build && pnpm run ci:e2e"
  },
  "dependencies": {
    "@react-three/fiber": "^9.4.0",
    "blueimp-md5": "^2.19.0",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/blueimp-md5": "^2.18.2",
    "@types/node": "^24.10.3",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.182.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.15",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "jsdom": "^27.3.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vite": "^7.2.7",
    "vitest": "^4.0.15"
  }
}
